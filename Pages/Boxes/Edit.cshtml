@page
@model Inventario.Pages.Boxes.EditModel
@{
    ViewData["Title"] = "Editar contenedor";
}

<div class="section-title">
    <div>
        <p class="section-kicker">Ficha de contenedor</p>
        <h1>Editar contenedor</h1>
    </div>
    <a class="btn" asp-page="/Boxes/Details" asp-route-code="@Model.Input.Code">Volver</a>
</div>

<form class="panel form-grid" method="post">
    <input type="hidden" asp-for="Input.Id" />
    <div class="field">
        <label asp-for="Input.Code">CT público</label>
        <input asp-for="Input.Code" autocomplete="off" spellcheck="false" />
        <small class="caption">Cambiar CT afecta QR, etiquetas y búsqueda.</small>
        <span asp-validation-for="Input.Code"></span>
    </div>
    <div class="field">
        <label asp-for="Input.Name">Nombre</label>
        <input asp-for="Input.Name" />
    </div>
    <div class="field">
        <label asp-for="Input.ContainerType">Tipo</label>
        <select asp-for="Input.ContainerType" asp-items="Model.ContainerTypes"></select>
    </div>
    <div class="field" data-root-location-field hidden="@(Model.CanEditLocation ? (string?)null : "hidden")">
        <label asp-for="Input.LocationId">Ubicación</label>
        <select asp-for="Input.LocationId" asp-items="Model.Locations"></select>
        <span asp-validation-for="Input.LocationId"></span>
    </div>
    <div class="field" data-root-location-inherited hidden="@(!Model.CanEditLocation ? (string?)null : "hidden")">
        <label>Ubicación heredada</label>
        <div class="readonly-field">
            <strong>@(string.IsNullOrWhiteSpace(Model.InheritedLocationName) ? "Ubicación no disponible" : Model.InheritedLocationName)</strong>
            @if (!string.IsNullOrWhiteSpace(Model.InheritedLocationSourceLabel))
            {
                <small>@Model.InheritedLocationSourceLabel</small>
            }
        </div>
        <small class="caption">Solo los contenedores raíz permiten editar ubicación.</small>
    </div>
    <div class="field" data-parent-box-picker>
        <partial name="_SearchPicker" model="Model.ParentBoxPicker" />
    </div>
    <div class="field">
        <label asp-for="Input.Status">Estado</label>
        <select asp-for="Input.Status" asp-items="Html.GetEnumSelectList<BoxStatus>()"></select>
    </div>
    <div class="field full">
        <label asp-for="Input.Description">Descripción</label>
        <textarea asp-for="Input.Description"></textarea>
    </div>
    <div class="actions full">
        <button class="btn primary" type="submit">Guardar cambios</button>
    </div>
</form>