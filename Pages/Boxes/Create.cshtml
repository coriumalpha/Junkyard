@page
@model Inventario.Pages.Boxes.CreateModel
@{
    ViewData["Title"] = "Nuevo contenedor";
}

<div class="section-title">
    <div>
        <p class="section-kicker">Contenedor físico</p>
        <h1>Nuevo contenedor</h1>
    </div>
    <a class="btn" asp-page="/Boxes/Index">Volver</a>
</div>

<form class="panel form-grid" method="post">
    <div class="field">
        <label asp-for="Input.Code">Código</label>
        <input asp-for="Input.Code" placeholder="C04" />
        <span asp-validation-for="Input.Code"></span>
    </div>
    <div class="field">
        <label asp-for="Input.Name">Nombre</label>
        <input asp-for="Input.Name" placeholder="USB y alimentación" />
        <span asp-validation-for="Input.Name"></span>
    </div>
    <div class="field">
        <label asp-for="Input.ContainerType">Tipo</label>
        <select asp-for="Input.ContainerType" asp-items="Model.ContainerTypes"></select>
        <span asp-validation-for="Input.ContainerType"></span>
    </div>
    <div class="field">
        <label asp-for="Input.LocationId">Ubicación</label>
        <select asp-for="Input.LocationId" asp-items="Model.Locations"></select>
    </div>
    <div class="field">
        <label asp-for="Input.ParentBoxId">Dentro de otro contenedor</label>
        <select asp-for="Input.ParentBoxId" asp-items="Model.ParentBoxes"></select>
    </div>
    <div class="field">
        <label asp-for="Input.Status">Estado</label>
        <select asp-for="Input.Status" asp-items="Html.GetEnumSelectList<BoxStatus>()"></select>
    </div>
    <div class="field full">
        <label asp-for="Input.Description">Descripción</label>
        <textarea asp-for="Input.Description"></textarea>
    </div>
    <div class="actions full">
        <button class="btn primary" type="submit">Crear contenedor</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
