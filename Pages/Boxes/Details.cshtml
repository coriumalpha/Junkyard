@page "/boxes/{code}"
@model Inventario.Pages.Boxes.DetailsModel
@{
    ViewData["Title"] = Model.Box.Code;
}

<section class="detail-hero">
    <div>
        @if (TempData["HierarchyMessage"] is string hierarchyMessage)
        {
            <div class="notice toast stack-top">@hierarchyMessage</div>
        }
        @if (TempData["HierarchyError"] is string hierarchyError)
        {
            <div class="notice danger-zone toast stack-top">@hierarchyError</div>
        }
        @if (Model.Breadcrumb.Count > 0)
        {
            <nav class="box-breadcrumb" aria-label="Ruta del contenedor">
                <span class="eyebrow">Ruta física</span>
                <div class="box-breadcrumb-trail">
                    @for (var i = 0; i < Model.Breadcrumb.Count; i++)
                    {
                        var segment = Model.Breadcrumb[i];
                        if (!segment.IsLocation && segment.BoxId == Model.Box.Id)
                        {
                            <span class="box-breadcrumb-node current">@(!string.IsNullOrWhiteSpace(segment.Code) ? $"{segment.Code} · {segment.Label}" : segment.Label)</span>
                        }
                        else if (!segment.IsLocation && !string.IsNullOrWhiteSpace(segment.Code))
                        {
                            <a class="box-breadcrumb-node" asp-page="/Boxes/Details" asp-route-code="@segment.Code">@segment.Code · @segment.Label</a>
                        }
                        else
                        {
                            <span class="box-breadcrumb-node">@segment.Label</span>
                        }

                        @if (i < Model.Breadcrumb.Count - 1)
                        {
                            <span class="box-breadcrumb-separator">/</span>
                        }
                    }
                </div>
            </nav>
        }
        <div class="chips">
            <span class="chip good">@Model.Box.Code</span>
            <span class="chip">@Model.Box.ContainerTypeLabel</span>
            <span class="chip">@Model.Box.Status</span>
            <span class="chip">@Model.Box.LocationDisplay</span>
            @if (!string.IsNullOrWhiteSpace(Model.Box.EffectiveLocationSourceLabel))
            {
                <span class="chip">@Model.Box.EffectiveLocationSourceLabel</span>
            }
            @if (Model.Box.ParentBox is not null)
            {
                <a class="chip" asp-page="/Boxes/Details" asp-route-code="@Model.Box.ParentBox.Code">Dentro de @Model.Box.ParentBox.Code / @Model.Box.ParentBox.Name</a>
            }
            else
            {
                <span class="chip">En raíz</span>
            }
        </div>
        <h1>@Model.Box.Name</h1>
        <p class="muted">@Model.Box.Description</p>
        <div class="actions">
            <a class="btn primary" asp-page="/Items/Create" asp-route-boxId="@Model.Box.Id">Añadir ítem</a>
            <a class="btn" asp-page="/Boxes/Create" asp-route-parentBoxId="@Model.Box.Id">Crear subcontenedor</a>
            <a class="btn" asp-page="/Items/Index" asp-route-box="@Model.Box.Code" asp-route-includeChildren="false" asp-route-view="flat">Ver directo</a>
            <a class="btn" asp-page="/Items/Index" asp-route-box="@Model.Box.Code" asp-route-includeChildren="true" asp-route-view="grouped">Ver rama</a>
            <a class="btn" asp-page="/Boxes/Edit" asp-route-id="@Model.Box.Id">Editar contenedor</a>
        </div>
    </div>
    <div class="qr-panel">
        <div class="qr-card">
            <div class="qr">@Html.Raw(Model.QrSvg)</div>
            <span class="caption">/boxes/@Model.Box.Code</span>
            <button class="btn" type="button" onclick="window.print()">Imprimir etiqueta</button>
        </div>
    </div>
</section>

<section class="stats-grid stack-top">
    <article class="stat">
        <span>Ítems directos</span>
        <strong>@Model.DirectItemCount</strong>
    </article>
    <article class="stat">
        <span>Subcontenedores directos</span>
        <strong>@Model.DirectChildCount</strong>
    </article>
    <article class="stat">
        <span>Subcontenedores totales</span>
        <strong>@Model.DescendantBoxCount</strong>
    </article>
    <article class="stat">
        <span>Ítems en el subárbol</span>
        <strong>@Model.SubtreeItemCount</strong>
    </article>
</section>

<div class="split">
    <section>
        <section class="panel">
            <div class="section-header compact">
                <div>
                    <h2>Operar en Inventario</h2>
                    <p class="section-kicker">La ficha queda centrada en logística. Para operar con ítems, usa Inventario filtrado.</p>
                </div>
                <div class="actions">
                    <a class="btn primary" asp-page="/Items/Index" asp-route-box="@Model.Box.Code" asp-route-includeChildren="false" asp-route-view="flat">Vista plana</a>
                    <a class="btn" asp-page="/Items/Index" asp-route-box="@Model.Box.Code" asp-route-includeChildren="true" asp-route-view="grouped">Agrupado por contenedor</a>
                </div>
            </div>
            <div class="chips">
                <span class="chip">@Model.SubtreeItemCount ítems en el subárbol</span>
                <span class="chip">@Model.DescendantBoxCount subcontenedores descendientes</span>
                <span class="chip">@Model.Gallery.Count fotos propias</span>
            </div>
        </section>

        <div class="section-title">
            <div>
                <h2>Logística del contenedor</h2>
                <p class="section-kicker">Jerarquía, resumen físico y acceso al inventario filtrado.</p>
            </div>
        </div>
        <div class="logistics-stack">
            @if (Model.Box.ChildBoxes.Count > 0)
            {
                <section class="panel">
                <div class="section-header compact">
                    <div>
                        <h2>Subcontenedores</h2>
                        <p class="section-kicker">Contenedores hijos directos dentro de este nodo.</p>
                    </div>
                    <div class="actions">
                        <span class="chip">@Model.Box.ChildBoxes.Count</span>
                        <a class="btn" asp-page="/Boxes/Create" asp-route-parentBoxId="@Model.Box.Id">Crear subcontenedor</a>
                    </div>
                </div>
                <div class="box-content-grid">
                    @foreach (var child in Model.Box.ChildBoxes)
                    {
                        var itemLabel = child.Items.Count == 1 ? "1 ítem" : $"{child.Items.Count} ítems";
                        <a class="box-item-card subbox-card" asp-page="/Boxes/Details" asp-route-code="@child.Code">
                            @if (!string.IsNullOrWhiteSpace(child.CoverPhoto))
                            {
                                <img class="box-item-photo rotatable" style="@PhotoStorage.RotationStyle(Model.RotationFor(child.CoverPhoto))" src="@Model.ThumbUrl(child.CoverPhoto)" alt="@child.Name" loading="lazy" decoding="async" />
                            }
                            else
                            {
                                <div class="box-item-photo generated">@child.Code[..1]</div>
                            }
                                <span class="box-item-body">
                                <span class="chips"><span class="chip good">@child.Code</span><span class="chip">@child.ContainerTypeLabel</span></span>
                                <h3>@child.Name</h3>
                                <p class="caption">@child.LocationDisplay</p>
                                @if (!string.IsNullOrWhiteSpace(child.EffectiveLocationSourceLabel))
                                {
                                    <p class="caption">@child.EffectiveLocationSourceLabel</p>
                                }
                                <p class="caption">Dentro de @Model.Box.Code / @Model.Box.Name</p>
                                <p class="caption">@itemLabel</p>
                            </span>
                        </a>
                    }
                </div>
                </section>
            }

            <section class="panel inventory-actions-linked">
                <div class="section-header compact">
                    <div>
                        <p class="eyebrow">Pendientes</p>
                        <h2>Acciones vinculadas</h2>
                        <p class="section-kicker">Notas breves ligadas a este contenedor, sin convertir la ficha en un gestor de tareas.</p>
                    </div>
                    <div class="actions">
                        <a class="btn" asp-page="/Pendientes" asp-route-boxId="@Model.Box.Id">Añadir acción</a>
                        <a class="btn primary" asp-page="/Pendientes" asp-route-boxId="@Model.Box.Id" asp-route-showCompleted="true">Ver libreta</a>
                    </div>
                </div>
                @if (TempData["InventoryActionMessage"] is string inventoryActionMessage)
                {
                    <div class="notice toast stack-top">@inventoryActionMessage</div>
                }
                @if (Model.LinkedActions.Count == 0)
                {
                    <div class="empty">
                        <strong>No hay acciones abiertas.</strong>
                        <span>Si hay algo por revisar, podrás dejarlo aquí.</span>
                    </div>
                }
                else
                {
                    <div class="inventory-actions-list">
                        @foreach (var action in Model.LinkedActions)
                        {
                            <article class="panel inventory-action-card">
                                <div class="section-header compact">
                                    <div>
                                        <div class="chips">
                                            <span class="chip good">P@action.Priority</span>
                                            <span class="chip">@action.Status</span>
                                        </div>
                                        <h3>@action.Title</h3>
                                        @if (!string.IsNullOrWhiteSpace(action.Description))
                                        {
                                            <p class="caption">@action.Description</p>
                                        }
                                    </div>
                                    <div class="actions">
                                        <a class="btn" asp-page="/Pendientes" asp-route-boxId="@Model.Box.Id">Abrir en libreta</a>
                                        <form method="post" asp-page-handler="CompleteAction" asp-route-code="@Model.Box.Code" asp-route-actionId="@action.Id">
                                            <button class="btn primary" type="submit">Completar</button>
                                        </form>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="panel comments-panel">
                <div class="section-header compact">
                    <div>
                        <p class="eyebrow">Comentarios</p>
                        <h2>Notas sobre el contenedor</h2>
                        <p class="section-kicker">Contexto físico, incidencias o detalles útiles para seguir operando.</p>
                    </div>
                </div>
                @if (TempData["InventoryCommentMessage"] is string inventoryCommentMessage)
                {
                    <div class="notice toast stack-top">@inventoryCommentMessage</div>
                }
                <form class="form-grid stack-top" method="post" asp-page-handler="AddComment" asp-route-code="@Model.Box.Code">
                    <div class="field full">
                        <label asp-for="CommentText">Nuevo comentario</label>
                        <textarea asp-for="CommentText" rows="4" placeholder="Contexto, hallazgos, recordatorios..."></textarea>
                    </div>
                    <div class="actions full">
                        <button class="btn primary" type="submit">Guardar comentario</button>
                    </div>
                </form>
                @if (Model.Comments.Count == 0)
                {
                    <div class="empty stack-top">
                        <strong>No hay comentarios aún.</strong>
                        <span>Sirven para dejar contexto sin abrir una tarea nueva.</span>
                    </div>
                }
                else
                {
                    <div class="inventory-comments-list stack-top">
                        @foreach (var comment in Model.Comments)
                        {
                            <article class="panel inventory-comment-card">
                                <div class="section-header compact">
                                    <div>
                                        <div class="chips">
                                            <span class="chip">@comment.KindLabel</span>
                                            <span class="chip">@comment.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                                        </div>
                                        <p class="caption">@comment.Title</p>
                                        @if (!string.IsNullOrWhiteSpace(comment.Description))
                                        {
                                            <p class="item-description-text">@comment.Description</p>
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="panel">
                <div class="section-header compact">
                    <div>
                        <h2>Vista previa del contenido directo</h2>
                        <p class="section-kicker">Resumen corto para orientar; la operación real vive en Inventario filtrado.</p>
                    </div>
                    <div class="actions">
                        <span class="chip">@Model.DirectItemCount ítems directos</span>
                        <a class="btn primary" asp-page="/Items/Index" asp-route-box="@Model.Box.Code" asp-route-includeChildren="false" asp-route-view="flat">Ver directo</a>
                        <a class="btn" asp-page="/Items/Index" asp-route-box="@Model.Box.Code" asp-route-includeChildren="true" asp-route-view="grouped">Ver rama</a>
                    </div>
                </div>
                <div class="box-content-grid preview-grid">
                    @foreach (var item in Model.Box.Items.Take(6))
                    {
                        <a class="box-item-card" asp-page="/Items/Edit" asp-route-id="@item.Id">
                            @if (!string.IsNullOrWhiteSpace(item.CoverPhoto))
                            {
                                <img class="box-item-photo rotatable" style="@PhotoStorage.RotationStyle(Model.RotationFor(item.CoverPhoto))" src="@Model.ThumbUrl(item.CoverPhoto)" alt="@item.Name" loading="lazy" decoding="async" />
                            }
                            else
                            {
                                <div class="box-item-photo generated">@item.Name[..1]</div>
                            }
                            <span class="box-item-body">
                                <h3>@item.Name</h3>
                                <p class="caption">@item.Category · @item.Quantity @item.Unit</p>
                                <span class="chips">
                                    @if (item.Consumable)
                                    {
                                        <span class="chip @(item.MinQuantity != null && item.Quantity <= item.MinQuantity ? "danger" : "good")">stock @item.Quantity @item.Unit</span>
                                    }
                                    @if (item.Sentimental)
                                    {
                                        <span class="chip good">recuerdo</span>
                                    }
                                    @if (item.Obsolete)
                                    {
                                        <span class="chip warn">legacy</span>
                                    }
                                </span>
                            </span>
                        </a>
                    }
                    @if (Model.Box.Items.Count == 0)
                    {
                        <div class="empty">
                            <strong>Sin ítems directos.</strong>
                            <span>Este contenedor no tiene ítems colgando directamente de él.</span>
                        </div>
                    }
                </div>
                @if (Model.Box.Items.Count > 6)
                {
                    <p class="caption">+@((Model.Box.Items.Count) - 6) ítems más visibles desde Inventario filtrado.</p>
                }
            </section>
        </div>
    </section>

    <aside>
        <section class="panel" id="hierarchy-actions">
            <div class="section-header compact">
                <div>
                    <h2>Jerarquía</h2>
                    <p class="section-kicker">Mover este contenedor como un nodo del árbol físico.</p>
                </div>
            </div>
            @if (Model.MoveBoxPicker.Options.Count == 0)
            {
                <div class="empty">
                    <strong>No hay destinos válidos.</strong>
                    <span>Ahora mismo no existe otro contenedor raíz o hermano válido donde moverlo.</span>
                </div>
            }
            else
            {
                <form class="form-grid" method="post" asp-page-handler="Move" asp-route-code="@Model.Box.Code">
                    <div class="field full">
                        <partial name="_SearchPicker" model="Model.MoveBoxPicker" />
                    </div>
                    <div class="actions full">
                        <button class="btn primary" type="submit">Mover a…</button>
                    </div>
                </form>
            }
            @if (Model.Box.ParentBox is not null)
            {
                <form class="stack-top" method="post" asp-page-handler="MoveToRoot" asp-route-code="@Model.Box.Code">
                    <button class="btn" type="submit">Sacar a raíz</button>
                </form>
            }
        </section>
        <div class="section-title" id="photos">
            <h2>Fotos</h2>
        </div>
        <form class="panel form-grid" method="post" enctype="multipart/form-data" asp-page-handler="Photo" asp-route-code="@Model.Box.Code">
            <div class="field full">
                <label>Imagen</label>
                <input type="file" asp-for="PhotoFile" accept="image/*" />
            </div>
            <div class="field full">
                <label>Pie</label>
                <input asp-for="Caption" />
            </div>
            <button class="btn primary full" type="submit">Subir foto</button>
        </form>
        <div class="gallery stack-top">
            @foreach (var photo in Model.Gallery)
            {
                var isCover = photo.Filename == Model.Box.CoverPhoto;
                <form class="photo-tile @(isCover ? "is-cover" : "")" method="post" asp-page-handler="ArchivePhoto" asp-route-code="@Model.Box.Code" asp-route-photoId="@photo.Id">
                    <img class="rotatable" style="@PhotoStorage.RotationStyle(photo.RotationDegrees)" src="@Model.ThumbUrl(photo)" alt="@photo.Caption" loading="lazy" decoding="async" />
                    <div class="photo-tile-actions">
                        @if (isCover)
                        {
                            <span class="badge good cover-badge">Principal</span>
                        }
                        else
                        {
                            <button class="btn" type="submit" asp-page-handler="SetCoverPhoto" asp-route-code="@Model.Box.Code" asp-route-photoId="@photo.Id">Usar como principal</button>
                        }
                        <button class="btn" type="submit" asp-page-handler="RotatePhoto" asp-route-code="@Model.Box.Code" asp-route-photoId="@photo.Id" asp-route-delta="-90">Girar izq.</button>
                        <button class="btn" type="submit" asp-page-handler="RotatePhoto" asp-route-code="@Model.Box.Code" asp-route-photoId="@photo.Id" asp-route-delta="90">Girar der.</button>
                        <button class="btn" type="submit" asp-page-handler="ReturnPhotoToInbox" asp-route-code="@Model.Box.Code" asp-route-photoId="@photo.Id">Devolver a bandeja</button>
                        <button class="btn danger" type="submit">Archivar</button>
                    </div>
                </form>
            }
        </div>
        <section class="panel danger-zone">
            <div>
                <h2>Zona peligrosa</h2>
                <p class="muted">Archiva el contenedor sin perder objetos. Si contiene ítems, podrás moverlos o dejarlos como huérfanos.</p>
            </div>
            <form method="post" asp-page-handler="Delete" asp-route-code="@Model.Box.Code">
                <button class="btn danger" type="submit">Archivar contenedor</button>
            </form>
        </section>
    </aside>
</div>
