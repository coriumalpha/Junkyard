<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Junkyard</title>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body data-icon-sprite="@Url.Content("~/lib/bootstrap-icons/bootstrap-icons.svg")">
@{
    var path = Context.Request.Path.Value ?? "/";
    var query = Context.Request.Query;
    var iconSprite = Url.Content("~/lib/bootstrap-icons/bootstrap-icons.svg");
    Microsoft.AspNetCore.Html.IHtmlContent Icon(string name) => new Microsoft.AspNetCore.Html.HtmlString($"<svg class=\"icon-svg\" aria-hidden=\"true\" focusable=\"false\"><use href=\"{iconSprite}#{name}\"></use></svg>");
    string Active(string prefix) => path.Equals(prefix, StringComparison.OrdinalIgnoreCase) || path.StartsWith(prefix + "/", StringComparison.OrdinalIgnoreCase) ? " active" : "";
    var boxesNav = "nav-link" + Active("/Boxes") + Active("/boxes");
    var inventoryNav = "nav-link" + Active("/items");
    var locationsNav = "nav-link" + Active("/Locations");
    var consumablesActive = Active("/Consumables");
    if (string.Equals(path, "/items", StringComparison.OrdinalIgnoreCase) && string.Equals(query["onlyConsumable"].ToString(), "true", StringComparison.OrdinalIgnoreCase))
    {
        consumablesActive = " active";
    }
    var consumablesNav = "nav-link" + consumablesActive;
    var photosNav = "nav-link" + Active("/photos");
    var actionsNav = "nav-link" + Active("/Pendientes");
    var archiveNav = "nav-link" + Active("/archive");
    var importNav = "nav-link" + Active("/Import");
    var exportNav = "nav-link" + Active("/Export");
}
    <header class="shell topbar">
        <a class="brand" asp-page="/Index">
            <img class="brand-logo" src="~/img/junkyard-logo.png" alt="" />
            <span>Junkyard</span>
        </a>
        <div class="top-search-shell" data-live-search-root data-live-search-mode="suggest" data-live-search-endpoint="/Search?handler=Live">
            <form class="top-search" asp-page="/Search" method="get">
                <input name="q" value="@Context.Request.Query["q"]" placeholder="Buscar objeto, caja, categoría, nota..." autocomplete="off" data-live-search-input />
            </form>
        </div>
        <nav>
            <a class="@boxesNav" asp-page="/Boxes/Index">@Icon("box-seam")<span>Cajas</span></a>
            <a class="@inventoryNav" asp-page="/Items/Index">@Icon("list-ul")<span>Inventario</span></a>
            <a class="@locationsNav" asp-page="/Locations">@Icon("geo-alt")<span>Ubicaciones</span></a>
            <a class="@consumablesNav" asp-page="/Items/Index" asp-route-onlyConsumable="true" asp-route-view="flat">@Icon("basket")<span>Consumibles</span></a>
            <a class="@photosNav" asp-page="/Photos/Inbox">@Icon("images")<span>Fotos</span></a>
            <a class="@actionsNav" asp-page="/Pendientes">@Icon("clock-history")<span>Pendientes</span></a>
            <a class="@archiveNav" asp-page="/Archive">@Icon("archive")<span>Archivo</span></a>
            <a class="@importNav" asp-page="/Import">@Icon("arrow-down-square")<span>Importar</span></a>
            <a class="@exportNav" asp-page="/Export">@Icon("arrow-up-square")<span>Exportar</span></a>
        </nav>
    </header>
    <main class="shell page">
        @RenderBody()
    </main>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
